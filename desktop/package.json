{
  "name": "deepseek-agent-desktop",
  "version": "0.0.2",
  "description": "DeepSeek Agent Desktop - Local file access and command execution",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "native": "node src/main/main.js --native-messaging",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "author": "DeepSeek Agent",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {},
  "build": {
    "appId": "com.deepseek.agent.desktop",
    "productName": "DeepSeek-Agent-Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json",
      "native-host/**/*"
    ],
    "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
    "artifactName": "${productName}-${version}.${ext}",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "linux": {
      "target": ["AppImage"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    }
  }
}
